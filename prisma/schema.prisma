// eKonobar — Prisma Schema v1.0
// Baza: PostgreSQL
// Generisano prema arhitekturnom dokumentu v1.0

generator client {
  // Prisma 6.7 emits OpenTelemetry query spans out of the box (tracing is GA —
  // no preview flag needed). Consumed by Sentry.prismaIntegration() in
  // sentry.server.config.ts so DB latency is attributable in distributed traces.
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  // Runtime: Supabase pooled connection (pgBouncer, port 6543, ?pgbouncer=true).
  // Serverless functions churn connections — the pooler prevents exhausting Postgres.
  url       = env("DATABASE_URL")
  // Migrations / introspection need a direct connection (port 5432, no pooler).
  // pgBouncer transaction mode can't run migration DDL. Docker deploy sets
  // DIRECT_URL = DATABASE_URL (in-network db, no pooler) so migrate deploy works there too.
  directUrl = env("DIRECT_URL")
}

// ─── Enumi ────────────────────────────────────────────────────────────────────

enum Role {
  WAITER
  VENUE_OWNER
  HEADHUNTER
  ADMIN
  GUEST
}

enum VerificationTier {
  UNVERIFIED
  SILVER        // Verifikovano ugovorom o radu (admin odobrio)
  GOLD          // Verifikovano invite kodom od vlasnika lokala
  ID_VERIFIED   // Potvrđen ličnim dokumentom (JMBG) — težina ocene ×1.2
}

enum VenueType {
  RESTAURANT
  CAFE
  BAR
  CATERING
  HOTEL
  EVENT
}

enum EngagementType {
  FULL_TIME
  SEASONAL
  WEEKEND
  CELEBRATION
}

enum TipSystem {
  INDIVIDUAL      // Konobar zadržava bakšiš za sebe
  SHARED          // Zajednički fond, podela po dogovoru
  VENUE_POLICY    // Politika lokala (opisano u tipDescription)
}

enum JobPostStatus {
  ACTIVE
  PAUSED
  FILLED
  EXPIRED
  DELETED
}

enum ApplicationStatus {
  PENDING
  SHORTLISTED
  ACCEPTED
  REJECTED
  WITHDRAWN
  COMPLETED
}

enum ReviewDirection {
  WAITER_TO_VENUE   // Konobar ocenjuje lokal
  VENUE_TO_WAITER   // Lokal ocenjuje konobara
  GUEST_TO_WAITER   // Gost ocenjuje konobara (zahteva geofencing)
  GUEST_TO_VENUE    // Gost ocenjuje lokal (atmosfera, usluga, čistoća)
}

enum ReviewStatus {
  PENDING     // Čeka objavu (window period)
  PUBLISHED
  DISPUTED
  REMOVED
}

enum ZoneType {
  FESTIVAL_ZONE   // = EXPO — Sajam, festival
  TRANSIT_HUB     // = METRO — Čvorište prevoza
  DEVELOPMENT     // = INFRASTRUCTURE — Nova zona razvoja
  NIGHTLIFE       // = NIGHTLIFE — Noćni klubovi
  TOURIST_AREA    // = QUIET_ZONE — Turistička zona
  STUDENT_AREA    // = STUDENT_FAKULTETI
  RESIDENTIAL     // = STUDENT_DOM — Stambena zona
}

enum SanitaryStatus {
  PENDING
  APPROVED
  REJECTED
  EXPIRED
}

enum ShiftStatus {
  OPEN           // no assignments yet — visible in marketplace
  ASSIGNED       // all required slots filled
  PENDING_SWAP   // at least one swap request live
  LOCKED         // owner locked, no swaps allowed
  COMPLETED
  CANCELLED
}

enum ClockInMethod {
  GPS
  GPS_GRACE
  QR
  MANUAL
}

enum SwapRequestStatus {
  PENDING
  ACCEPTED
  REJECTED
  CANCELLED
}

// ─── Osoblje (staff roster) ──────────────────────────────────────────────────
// Department + position live on the roster, not on Role. Role.WAITER means
// "hospitality worker" — a cook registers as WAITER and is distinguished here.
// See lib/staff/positions.ts for the position → department map (source of truth).

enum StaffDepartment {
  FOH   // Sala
  BOH   // Kuhinja
}

enum StaffPosition {
  // FOH — Sala
  WAITER            // Konobar
  SENIOR_WAITER     // Iskusni konobar
  HEAD_WAITER       // Šef sale
  BARTENDER         // Šanker
  BARISTA           // Barista
  RUNNER            // Runner / pomoćni konobar
  HOST              // Hostesa
  SOMMELIER         // Somelijer

  // BOH — Kuhinja
  HEAD_CHEF         // Šef kuhinje
  SOUS_CHEF         // Su-šef
  LINE_COOK         // Kuvar
  PREP_COOK         // Pomoćni kuvar
  PASTRY_CHEF       // Poslastičar
  GRILL_COOK        // Roštiljdžija
  DISHWASHER        // Perač suđa
}

enum StaffStatus {
  ACTIVE
  SUSPENDED
  ENDED
}

// ─── Odmori (leave) ──────────────────────────────────────────────────────────

enum LeaveType {
  ANNUAL     // Godišnji odmor
  SICK       // Bolovanje — never deducted from the annual balance
  UNPAID     // Neplaćeno odsustvo
  PARENTAL   // Roditeljsko
  SPECIAL    // Plaćeno odsustvo (svadba, smrtni slučaj…)
}

enum LeaveStatus {
  PENDING
  APPROVED
  REJECTED
  CANCELLED
}

enum NotificationType {
  APPLICATION_RECEIVED           // waiter applied → venue owner
  APPLICATION_STATUS_CHANGED     // status updated → waiter
  SWAP_REQUESTED                 // swap created → target waiter + venue owner
  SWAP_RESOLVED                  // swap accepted/rejected → both waiters
  SHIFT_CLAIMED                  // waiter claimed open shift → venue owner
  SHIFT_ASSIGNED                 // owner assigned waiter → waiter
  REVIEW_RECEIVED                // new review submitted → venue owner
  REVIEW_PUBLISHED               // review went live → subject
  CLOCKIN_APPROVAL_REQUESTED     // waiter outside geofence → venue owner
  CLOCKIN_RESOLVED               // owner approved/rejected clock-in → waiter
  RED_ALERT_POSTED               // new Red Alert job in a waiter's reach → matching available waiters
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id            String           @id @default(cuid())
  email         String           @unique
  emailVerified DateTime?
  name          String?
  image         String?
  hashedPassword String?

  role              Role             @default(WAITER)
  verificationTier  VerificationTier @default(UNVERIFIED)

  // JMBG — čuvamo samo hash, nikad plaintext (privatnost)
  jmbgHash      String?   @unique
  idVerifiedAt  DateTime?

  rememberMe      Boolean   @default(false)
  lastLoginAt     DateTime?
  tourCompleted   Boolean   @default(false)

  // Notification preferences
  phone         String?
  smsOptIn      Boolean   @default(false)  // Infobip premium SMS
  waOptIn       Boolean   @default(false)  // WhatsApp

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  // Relacije
  accounts          Account[]
  sessions          Session[]
  venues            Venue[]             @relation("VenueOwner")
  headWaiterVenues  Venue[]             @relation("VenueHeadWaiter")
  headChefVenues    Venue[]             @relation("VenueHeadChef")
  staffRoles        VenueStaff[]        @relation("VenueStaffMember")
  jobPosts          JobPost[]
  applications      JobApplication[]
  reviewsGiven      Review[]            @relation("ReviewAuthor")
  reviewsReceived   Review[]            @relation("ReviewSubject")
  waiterPassport    WaiterPassport?
  engagementRecords EngagementRecord[]  @relation("WaiterEngagements")
  shiftAssignments  ShiftAssignment[]
  swapRequestsReceived ShiftSwapRequest[] @relation("SwapTarget")
  sanitaryBook      SanitaryBook?
  savedProfiles     SavedProfile[]      @relation("HeadhunterSaved")
  savedAsProfile    SavedProfile[]      @relation("HeadhunterSavedWaiter")
  invitesSent       Invite[]            @relation("InviteSender")
  invitesUsed       Invite[]            @relation("InviteRecipient")
  rateLimits        RateLimit[]
  notifications     Notification[]
  pushSubscriptions PushSubscription[]
  passportPayments     PassportPayment[]
  passwordResetTokens  PasswordResetToken[]
  tokenRevocation      TokenRevocation?
  auditLogs            AuditLog[]

  @@index([role])
  @@index([verificationTier])
  @@index([deletedAt])
}

// ─── NextAuth ─────────────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Venue (Lokal) ────────────────────────────────────────────────────────────

model Venue {
  id          String    @id @default(cuid())
  ownerId     String
  owner       User      @relation("VenueOwner", fields: [ownerId], references: [id])

  headWaiterId String?
  headWaiter   User?   @relation("VenueHeadWaiter", fields: [headWaiterId], references: [id])

  // Šef kuhinje — symmetric to headWaiter, but scoped to BOH shifts/leave.
  headChefId   String?
  headChef     User?   @relation("VenueHeadChef", fields: [headChefId], references: [id])

  // null = derive from venueType (see hasKitchen() in lib/staff/positions.ts).
  // Explicit value overrides: a bar that started serving food, a restaurant
  // that outsources its kitchen.
  kitchenEnabled Boolean?

  name        String
  description String?   @db.Text
  address     String
  municipality String
  city        String    @default("Beograd")

  venueType   VenueType
  cuisineTypes String[]
  capacity    Int?

  latitude    Float
  longitude   Float
  reviewRadiusKm  Float   @default(0.15)  // 150m default za geofencing
  geofenceEnabled Boolean @default(true)  // secure default: require geofence; owners may opt out

  // Cenovni raspon (RSD/h)
  priceRangeMin Float?
  priceRangeMax Float?

  images      String[]
  logo        String?

  trustScore  Float     @default(0)
  venueInsights Json?   // venueZone, blizina, tip — analogno growthInsights

  website     String?
  phone       String?
  instagram   String?

  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  // Relacije
  jobPosts          JobPost[]
  reviews           Review[]
  engagementRecords EngagementRecord[]
  shifts            Shift[]
  shiftTemplates    ShiftTemplate[]
  venueTrustScore   VenueTrustScore?
  zones             VenueZoneRelation[]
  staff             VenueStaff[]
  leavePolicies     LeavePolicy[]
  blackoutDates     VenueBlackoutDate[]

  @@index([municipality])
  @@index([venueType])
  @@index([latitude, longitude])
  @@index([deletedAt])
  @@index([trustScore])
}

// ─── JobPost (Oglas za posao) ─────────────────────────────────────────────────

model JobPost {
  id      String  @id @default(cuid())
  venueId String
  venue   Venue   @relation(fields: [venueId], references: [id])
  ownerId String
  owner   User    @relation(fields: [ownerId], references: [id])

  title       String
  description String  @db.Text

  engagementType  EngagementType
  salaryMin       Float?
  salaryMax       Float?

  tipSystem       TipSystem
  tipDescription  String?   // "Bakšiš se deli 70/30 kuhinja-sala"

  sanitaryRequired Boolean  @default(false)

  startDate       DateTime?
  endDate         DateTime?     // null = stalna pozicija
  applicationDeadline DateTime?

  // Red Alert — hitna smena
  redAlert        Boolean   @default(false)
  redAlertNote    String?   // "Potreban danas do 18h"

  inviteCode      String?   @unique  // za direktno pozivanje konobara

  status          JobPostStatus @default(ACTIVE)

  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  applications    JobApplication[]
  engagementRecords EngagementRecord[]

  @@index([venueId, status])
  @@index([engagementType])
  @@index([redAlert])
  @@index([sanitaryRequired])
  @@index([deletedAt])
}

// ─── JobApplication (Prijava na oglas) ───────────────────────────────────────

model JobApplication {
  id        String  @id @default(cuid())
  jobPostId String
  jobPost   JobPost @relation(fields: [jobPostId], references: [id])
  waiterId  String
  waiter    User    @relation(fields: [waiterId], references: [id])

  coverNote   String?  @db.Text
  status      ApplicationStatus @default(PENDING)

  appliedAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([jobPostId, waiterId])
  @@index([waiterId])
  @@index([status])
  @@index([jobPostId, status])
}

// ─── Review (Recenzija) ───────────────────────────────────────────────────────

model Review {
  id          String  @id @default(cuid())
  authorId    String?                // null for anonymous guest reviews
  author      User?   @relation("ReviewAuthor", fields: [authorId], references: [id])
  guestHandle String?                // optional display name for guest reviews
  subjectId   String?
  subject     User?   @relation("ReviewSubject", fields: [subjectId], references: [id])
  venueId     String?
  venue       Venue?  @relation(fields: [venueId], references: [id])

  direction   ReviewDirection
  status      ReviewStatus    @default(PENDING)

  // Zajednički
  overallRating Int   // 0-100 (klijent šalje 1-5 zvezdica × 20)
  comment       String? @db.Text

  // Težina ocene — ID_VERIFIED autori dobijaju ×1.2 pri kreiranju review-a
  weight             Float @default(1.0)

  // WAITER_TO_VENUE kategorije
  ratingAtmosphere   Int?  // Radna atmosfera
  ratingOrganization Int?  // Organizacija smena
  ratingPay          Int?  // Redovnost isplate
  ratingTips         Int?  // Sistem podele bakšiša
  ratingHygieneWork  Int?  // Higijenske uslove u lokalu (radni uslovi)
  ratingManagement   Int?  // Komunikacija menadžmenta

  // VENUE_TO_WAITER kategorije
  ratingPunctuality        Int?  // Tačnost i pouzdanost
  ratingSkill              Int?  // Profesionalne veštine
  ratingGuestCommunication Int?  // Komunikacija sa gostima
  ratingPersonalHygiene    Int?  // Lična higijena konobara
  ratingTeamwork           Int?  // Timski rad
  ratingSpeed              Int?  // Brzina usluge

  // GUEST_TO_WAITER kategorije
  ratingFriendliness   Int?  // Ljubaznost
  ratingGuestSpeed     Int?  // Brzina usluge (gostinska percepcija)
  ratingAttentiveness  Int?  // Pažljivost

  // Geofencing (samo za GUEST_TO_WAITER)
  guestLatitude   Float?
  guestLongitude  Float?
  geolocationHash String?  // SHA-256(lat+lng+timestamp) — dokaz lokacije

  pendingUntil  DateTime?   // Kada se objavljuje (PENDING → PUBLISHED)
  publishedAt   DateTime?
  disputedAt    DateTime?

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // 3-column composites cover sync-scores queries (subjectId/venueId + direction + status)
  // and also serve as prefix indexes for any 2-column queries on the first two columns.
  @@index([subjectId, direction, status])
  @@index([venueId, direction, status])
  @@index([status])
  @@index([pendingUntil])
}

// ─── WaiterPassport (Digitalni pasoš) ────────────────────────────────────────

model WaiterPassport {
  id      String  @id @default(cuid())
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  score               Float   @default(0)   // 0-100 Bayesian
  badges              String[]
  reviewCount         Int     @default(0)
  totalEngagements    Int     @default(0)
  avgEngagementMonths Float   @default(0)

  skills              String[]  // ["cocktail", "fine dining", "kafe aparat", "sommelier"]
  languages           String[]  // ["srpski", "engleski", "nemački"]
  yearsExperience     Int       @default(0)

  sanitaryBookValid   Boolean   @default(false)
  sanitaryExpiry      DateTime?

  currentlyAvailable  Boolean   @default(true)

  shareToken          String?   @unique
  shareTokenExpiry    DateTime?

  bio                 String?   @db.Text
  profilePhoto        String?
  galleryPhotos       String[]

  venueTypePreferences String[]  // ["RESTAURANT", "CAFE", "BAR", "NIGHT_CLUB", "HOTEL", "CATERING"]

  // Reach — Belgrade gradske opštine the waiter will work in (canonical list in
  // lib/geo/municipalities.ts). Venue owners filter search by these. No home
  // coordinates are stored: the question is "will he come", not "where he sleeps".
  workMunicipalities   String[]

  avgRedAlertResponseMinutes Float?  // rolling avg minutes from Red Alert post to application
  redAlertResponseCount      Int    @default(0)

  lastAvailableDate   DateTime?  // set when currentlyAvailable flips true, cleared when flips false

  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  trustScore          PassportTrustScore?

  @@index([score])
}

// ─── Trust Score modeli ───────────────────────────────────────────────────────

model PassportTrustScore {
  id        String         @id @default(cuid())
  passportId String        @unique
  passport  WaiterPassport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  // Dimenzije za konobara (0-100 Bayesian)
  punctuality       Float @default(0)
  skill             Float @default(0)
  guestCommunication Float @default(0)
  personalHygiene   Float @default(0)
  teamwork          Float @default(0)
  speed             Float @default(0)

  composite         Float @default(0)
  sampleSize        Int   @default(0)

  updatedAt         DateTime @updatedAt
}

model VenueTrustScore {
  id      String  @id @default(cuid())
  venueId String  @unique
  venue   Venue   @relation(fields: [venueId], references: [id], onDelete: Cascade)

  // Dimenzije za lokal (0-100 Bayesian)
  atmosphere    Float @default(0)
  organization  Float @default(0)
  pay           Float @default(0)
  tips          Float @default(0)
  hygieneStandards Float @default(0)
  management    Float @default(0)

  composite     Float @default(0)
  sampleSize    Int   @default(0)

  updatedAt     DateTime @updatedAt
}

// ─── EngagementRecord (Istorija angažmana) ───────────────────────────────────

model EngagementRecord {
  id        String  @id @default(cuid())
  waiterId  String
  waiter    User    @relation("WaiterEngagements", fields: [waiterId], references: [id])
  venueId   String
  venue     Venue   @relation(fields: [venueId], references: [id])
  jobPostId String?
  jobPost   JobPost? @relation(fields: [jobPostId], references: [id])

  startDate       DateTime
  endDate         DateTime?
  engagementType  EngagementType

  verified        Boolean   @default(false)  // true = vlasnik lokala potvrdio
  verifiedAt      DateTime?

  notes           String?   @db.Text  // privatna beleška konobara

  createdAt       DateTime  @default(now())

  @@index([waiterId])
  @@index([venueId])
}

// ─── SanitaryBook (Sanitarna knjižica) ───────────────────────────────────────

model SanitaryBook {
  id      String  @id @default(cuid())
  userId  String  @unique
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  fileUrl     String
  status      SanitaryStatus @default(PENDING)
  expiryDate  DateTime?

  reviewedBy  String?  // Admin userId
  reviewedAt  DateTime?
  rejectReason String?

  uploadedAt  DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

enum InviteType {
  VERIFICATION   // referral / onboarding code
  JOB_INVITE     // venue owner inviting a waiter to a job post
}

enum InviteStatus {
  PENDING
  ACCEPTED
  DECLINED
  EXPIRED
}

// ─── Invite ───────────────────────────────────────────────────────────────────

model Invite {
  id          String       @id @default(cuid())
  senderId    String
  sender      User         @relation("InviteSender", fields: [senderId], references: [id])
  recipientId String?
  recipient   User?        @relation("InviteRecipient", fields: [recipientId], references: [id])

  code        String       @unique @default(cuid())
  venueId     String?
  jobPostId   String?

  type        InviteType   @default(VERIFICATION)
  status      InviteStatus @default(PENDING)
  message     String?      @db.Text

  usedAt      DateTime?
  expiresAt   DateTime

  createdAt   DateTime     @default(now())

  @@index([code])
  @@index([senderId])
  @@index([recipientId])
}

// ─── VenueZone (Zona na mapi) ─────────────────────────────────────────────────

model VenueZone {
  id          String    @id @default(cuid())
  name        String
  zoneType    ZoneType
  description String?

  // GeoJSON polygon ili bounding box
  geoJson     Json

  // Centar zone (za distance kalkulacije)
  centerLat   Float
  centerLng   Float
  radiusKm    Float  @default(1.0)  // radijus zone za intersection check

  // Analitika zone
  projectedGrowthPercent Float   @default(0)
  operatorTip            String? // savjet za vlasnike lokala u zoni

  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  venues      VenueZoneRelation[]

  @@index([zoneType])
}

model VenueZoneRelation {
  venueId   String
  venue     Venue     @relation(fields: [venueId], references: [id])
  zoneId    String
  zone      VenueZone @relation(fields: [zoneId], references: [id])

  @@id([venueId, zoneId])
}

// ─── SavedProfile (Headhunter — sačuvani profili) ────────────────────────────

model SavedProfile {
  id            String  @id @default(cuid())
  headhunterId  String
  headhunter    User    @relation("HeadhunterSaved", fields: [headhunterId], references: [id])

  savedWaiterId String
  savedWaiter   User    @relation("HeadhunterSavedWaiter", fields: [savedWaiterId], references: [id], onDelete: Cascade)
  notes         String?

  savedAt       DateTime @default(now())

  @@unique([headhunterId, savedWaiterId])
  @@index([headhunterId])
}

// ─── Shift (Smena) ───────────────────────────────────────────────────────────

// ─── VenueStaff (roster) ─────────────────────────────────────────────────────
// The durable "who works here" record. Before this, a venue's team was derived
// client-side from ACCEPTED JobApplications, which lost anyone hired off-platform,
// dropped people once their application went COMPLETED, and carried no start date
// (so first-year leave could not be pro-rated).

model VenueStaff {
  id       String @id @default(cuid())
  venueId  String
  venue    Venue  @relation(fields: [venueId], references: [id])
  waiterId String
  waiter   User   @relation("VenueStaffMember", fields: [waiterId], references: [id])

  position   StaffPosition
  // Denormalized from position so per-department queries stay indexable.
  // Always derived via departmentOf() and validated on write — a FOH+HEAD_CHEF
  // row must be impossible.
  department StaffDepartment

  status         StaffStatus    @default(ACTIVE)
  employmentType EngagementType
  startedAt      DateTime
  endedAt        DateTime?

  notes String? @db.Text

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([venueId, waiterId])
  @@index([venueId, status])
  @@index([venueId, department, status])
  @@index([waiterId])
}

// ─── LeavePolicy ─────────────────────────────────────────────────────────────
// One row per (venue, department). Kitchens and floors commonly negotiate leave
// differently, and capacity must be counted per department — two waiters off is
// not the same as two cooks off.

model LeavePolicy {
  id         String          @id @default(cuid())
  venueId    String
  venue      Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  department StaffDepartment

  // 26 is a house default, above the Serbian statutory minimum of 20 working
  // days (Zakon o radu čl. 69). Deliberately configurable, never hardcoded.
  annualDays Int @default(26)

  // Default cap on how many people may be off on the same day. A blackout row
  // overrides it per date; maxOff = 0 there means "everyone works".
  maxConcurrentOff Int @default(2)

  minNoticeDays Int     @default(14)
  // Requests that clear every check are approved without a human. The premise is
  // "everything free unless the owner says otherwise" — routing every request to
  // an approval queue is what makes owners abandon the feature.
  autoApprove   Boolean @default(true)
  // Hospitality staff work weekends; skipping Sat/Sun would silently gift days.
  countWeekends Boolean @default(true)

  allowCarryOver    Boolean @default(true)
  carryOverDays     Int     @default(5)
  carryOverDeadline String  @default("06-30")  // MM-DD

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([venueId, department])
}

// ─── VenueBlackoutDate ───────────────────────────────────────────────────────
// Sparse: only days that deviate from the policy default are stored. Absence of
// a row means "normal policy applies", which is the intended default of
// everything being available.

model VenueBlackoutDate {
  id         String          @id @default(cuid())
  venueId    String
  venue      Venue           @relation(fields: [venueId], references: [id], onDelete: Cascade)
  department StaffDepartment
  date       DateTime        @db.Date

  // 0 = fully blocked ("X" in the UI). >0 = reduced cap for that day.
  maxOff Int     @default(0)
  reason String?

  createdAt DateTime @default(now())

  @@unique([venueId, department, date])
  @@index([venueId, date])
}

model Shift {
  id        String   @id @default(cuid())
  venueId   String
  venue     Venue    @relation(fields: [venueId], references: [id])

  title          String
  date           DateTime
  startTime      String   // "18:00" — kept for display
  endTime        String   // "02:00" — kept for display
  scheduledStart DateTime? // full UTC DateTime for clock-in window checks (null for legacy rows)
  role           String?
  // Which department the shift belongs to. Scopes head-waiter vs head-chef
  // management rights (lib/shifts/auth.ts). Null = legacy row, treated as FOH.
  department     StaffDepartment?
  requiredCount  Int      @default(1)
  tipEstimate    Float?   // expected RSD tips — shown in marketplace
  pay            Int?
  briefingNote   String?  @db.Text
  notes          String?  @db.Text

  templateId String?     // set when generated from ShiftTemplate
  template   ShiftTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)

  status     ShiftStatus @default(OPEN)
  swapLocked Boolean     @default(false)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assignments  ShiftAssignment[]
  swapRequests ShiftSwapRequest[]

  @@index([venueId])
  @@index([date])
  @@index([scheduledStart])
  @@index([status])
  @@index([templateId, date])
}

model ShiftAssignment {
  id       String @id @default(cuid())
  shiftId  String
  shift    Shift  @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  waiterId String
  waiter   User   @relation(fields: [waiterId], references: [id])

  clockInAt     DateTime?
  clockOutAt    DateTime?
  clockInMethod ClockInMethod?
  clockInLat    Float?
  clockInLng    Float?
  earlyExitAt    DateTime?
  lateMinutes    Int?       // actual - scheduled start in minutes
  cancelledLate  Boolean    @default(false)
  pendingClockIn Boolean    @default(false) // awaiting manager approval (GPS outside geofence)

  createdAt DateTime @default(now())

  swapRequestsFrom ShiftSwapRequest[] @relation("SwapFromAssignment")

  @@unique([shiftId, waiterId])
  @@index([waiterId])
  @@index([shiftId])
  @@index([pendingClockIn])
}

model ShiftSwapRequest {
  id               String    @id @default(cuid())
  shiftId          String
  shift            Shift     @relation(fields: [shiftId], references: [id])
  fromAssignmentId String
  fromAssignment   ShiftAssignment @relation("SwapFromAssignment", fields: [fromAssignmentId], references: [id])
  toWaiterId       String
  toWaiter         User      @relation("SwapTarget", fields: [toWaiterId], references: [id])

  status      SwapRequestStatus @default(PENDING)
  requestedAt DateTime          @default(now())
  resolvedAt  DateTime?

  @@index([shiftId])
  @@index([toWaiterId])
  @@index([status])
}

model ShiftTemplate {
  id          String @id @default(cuid())
  venueId     String
  venue       Venue  @relation(fields: [venueId], references: [id])

  name          String
  dayOfWeek     Int?           // 0=Sun…6=Sat; null when weekdaysOnly=true
  weekdaysOnly  Boolean        @default(false)
  metadata      Json?          // { type: "morning"|"evening", label: string, shift: "1"|"2" }
  startTime     String
  endTime       String
  requiredCount Int            @default(1)
  role          String?
  pay           Int?

  createdAt DateTime @default(now())

  generatedShifts Shift[]

  @@index([venueId])
}

// ─── RateLimit (DB-backed rate limiter) ──────────────────────────────────────

model RateLimit {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  action    String   // npr. "post_review", "apply_job"
  count     Int      @default(1)
  windowStart DateTime

  @@unique([userId, action, windowStart])
  @@index([userId, action])
}

// ─── Notification ─────────────────────────────────────────────────────────────

model Notification {
  id       String           @id @default(cuid())
  userId   String
  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  type     NotificationType
  title    String
  body     String
  link     String?

  read     Boolean @default(false)
  pushSent Boolean @default(false)
  waSent   Boolean @default(false)
  smsSent  Boolean @default(false)

  // Retry counters — incremented on send failure; cron skips when >= 3
  waRetries  Int @default(0)
  smsRetries Int @default(0)

  createdAt DateTime @default(now())

  @@index([userId, read])
  @@index([userId, createdAt])
}

// ─── PushSubscription (Web Push) ─────────────────────────────────────────────

model PushSubscription {
  id       String @id @default(cuid())
  userId   String
  user     User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  endpoint String @unique
  p256dh   String
  auth     String

  createdAt DateTime @default(now())

  @@index([userId])
}

// ─── PassportPayment (Monri transaction log) ──────────────────────────────────

model PassportPayment {
  id          String       @id @default(cuid())
  userId      String
  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  orderNumber String       @unique  // eKonobar-generated, sent to Monri
  // Historical record only — the waiter subscription product was removed. Kept as a
  // free-text label so past payment rows stay readable without a live tier enum.
  tier        String
  amountRsd   Int                   // 29000 = 290.00 RSD (minor units)

  status      String       @default("PENDING")  // PENDING | SUCCESS | FAILED | CANCELLED
  monriApprovalCode String?
  monriPanToken     String?          // stored if tokenize_pan was requested

  // Set atomically on first callback receipt — prevents concurrent/retried callbacks
  // from double-activating a subscription. NULL = not yet received.
  callbackReceivedAt DateTime?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([orderNumber])
  @@index([status])
}

// ─── AnonRateLimit (IP / pre-auth rate limiting — no FK) ─────────────────────
//
// Used for: login:ip:*, forgot:*, guest_review:*
// Key format: "<action>:<value>"  e.g. "login:ip:1.2.3.4"
// No userId FK so it works before a User row exists.

model AnonRateLimit {
  key         String
  windowStart DateTime
  count       Int      @default(1)

  @@id([key, windowStart])
  @@index([key])
}

// ─── Password Reset ───────────────────────────────────────────────────────────

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─── Token Revocation ─────────────────────────────────────────────────────────
// Tracks the latest revocation timestamp per user. Any JWT issued before
// revokedAt is treated as invalid on the next getServerSession() call.
// Written on admin role-change and soft-delete; checked in the jwt callback
// via a 60s in-process cache to limit DB load.

model TokenRevocation {
  userId    String   @id
  revokedAt DateTime
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(cuid())
  actorId    String
  action     String   // USER_ROLE_CHANGED | USER_DELETED | USER_RESTORED | REVIEW_PUBLISHED | REVIEW_REMOVED | SANITARY_APPROVED | SANITARY_REJECTED
  targetId   String
  targetType String   // User | Review | SanitaryBook
  meta       Json?
  createdAt  DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([actorId])
  @@index([targetId])
  @@index([createdAt])
}
