# ── Production env for docker-compose.prod.yml ──────────────────────────────
# Copy to .env.production on the server and fill in. NEVER commit .env.production.
#
# NOTE: DATABASE_URL, REDIS_URL and TRUST_PROXY are set by docker-compose.prod.yml
# (in-network hostnames) — do not set them here.

# Compose-level (interpolated into docker-compose.prod.yml)
DOMAIN="ekonobar.rs"                       # your domain, DNS A record → server IP
POSTGRES_PASSWORD=""                       # generate: openssl rand -hex 24

# App URLs — must be https://<DOMAIN>
NEXTAUTH_URL="https://ekonobar.rs"
NEXT_PUBLIC_APP_URL="https://ekonobar.rs"

# Secrets
NEXTAUTH_SECRET=""                         # openssl rand -hex 32
CRON_SECRET=""                             # openssl rand -hex 32
MONRI_TOKEN_ENCRYPTION_KEY=""              # REQUIRED in prod: openssl rand -hex 32

# SMTP (password reset emails)
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="eKonobar <noreply@ekonobar.rs>"

# Mapbox (baked into client bundle at build time)
NEXT_PUBLIC_MAPBOX_TOKEN=""

# OAuth (optional)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# Web Push (VAPID) — npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_KEY=""                   # same as VAPID_PUBLIC_KEY

# Cloudinary (image uploads)
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# WhatsApp Business API (optional — no-op when empty)
WA_ACCESS_TOKEN=""
WA_PHONE_NUMBER_ID=""
WA_TEMPLATE_NAME="ekonobar_notification"

# Infobip SMS (optional — no-op when empty)
INFOBIP_API_KEY=""
INFOBIP_BASE_URL="https://api.infobip.com"
INFOBIP_FROM="eKonobar"

# Monri payment gateway
MONRI_ENV="production"                     # "test" until go-live
MONRI_MERCHANT_KEY=""
MONRI_AUTHENTICITY_TOKEN=""

# Sentry (optional)
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
