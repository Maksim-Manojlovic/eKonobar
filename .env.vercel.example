# ── Vercel + Supabase + Upstash env reference ───────────────────────────────
# NOT loaded automatically. Paste these into Vercel → Project → Settings →
# Environment Variables (Production). NEXT_PUBLIC_* must be set BEFORE the build
# (they are baked into the client bundle at build time).
#
# vercel-build (scripts/vercel-build.sh): prisma generate → migrate deploy (PRODUCTION
# deploys only) → next build. DATABASE_URL + DIRECT_URL must be reachable from Vercel's
# build step on production deploys.

# ── Database — Supabase (Project → Settings → Database → Connection string) ──
# DATABASE_URL = "Transaction" pooler (port 6543). Runtime uses this. pgbouncer=true
# disables prepared statements; connection_limit=1 keeps each serverless fn to one conn.
DATABASE_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
# DIRECT_URL = "Session"/direct connection (port 5432). Used ONLY for migrate deploy.
DIRECT_URL="postgresql://postgres.<ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres"

# ── Redis — Upstash (Database → Details → "TCP", NOT the REST URL) ───────────
# Must be rediss:// (TLS) — ioredis auto-enables TLS on the double-s scheme.
REDIS_URL="rediss://default:<token>@<name>.upstash.io:6379"

# ── App URLs ─────────────────────────────────────────────────────────────────
# Use the custom domain once attached; until then the *.vercel.app URL.
NEXTAUTH_URL="https://ekonobar.rs"
NEXT_PUBLIC_APP_URL="https://ekonobar.rs"

# Behind Vercel's edge — X-Forwarded-For is trustworthy here.
TRUST_PROXY="1"

# ── Secrets (openssl rand -hex 32) ───────────────────────────────────────────
NEXTAUTH_SECRET=""
CRON_SECRET=""                 # ALSO set as GitHub repo secret CRON_SECRET (cron.yml)
MONRI_TOKEN_ENCRYPTION_KEY=""  # REQUIRED in prod

# ── SMTP (password reset) ────────────────────────────────────────────────────
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"
SMTP_USER=""
SMTP_PASS=""
SMTP_FROM="eKonobar <noreply@ekonobar.rs>"

# ── Client-baked (set before build) ──────────────────────────────────────────
NEXT_PUBLIC_MAPBOX_TOKEN=""
NEXT_PUBLIC_VAPID_KEY=""        # same value as VAPID_PUBLIC_KEY

# ── Web Push (npx web-push generate-vapid-keys) ──────────────────────────────
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""

# ── Cloudinary (image uploads) ───────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Monri payment gateway ────────────────────────────────────────────────────
MONRI_ENV="test"               # flip to "production" at go-live
MONRI_MERCHANT_KEY=""
MONRI_AUTHENTICITY_TOKEN=""

# ── OAuth (optional) ─────────────────────────────────────────────────────────
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# ── WhatsApp / Infobip / Sentry (optional — no-op when empty) ────────────────
WA_ACCESS_TOKEN=""
WA_PHONE_NUMBER_ID=""
WA_TEMPLATE_NAME="ekonobar_notification"
INFOBIP_API_KEY=""
INFOBIP_BASE_URL="https://api.infobip.com"
INFOBIP_FROM="eKonobar"
SENTRY_DSN=""
NEXT_PUBLIC_SENTRY_DSN=""
