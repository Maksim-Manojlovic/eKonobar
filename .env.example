# Database — PostgreSQL
# Za Docker: postgresql://postgres:postgres@localhost:5432/appdb
# Za Docker Compose (unutar compose mreže): postgresql://postgres:postgres@db:5432/appdb
DATABASE_URL="postgresql://postgres:postgres@localhost:5433/appdb"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-here-generate-with-openssl-rand-base64-32"

# Mapbox
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ..."

# Opciono — geofencing default radius (fallback u kodu je 0.15)
DEFAULT_REVIEW_RADIUS_KM=0.15

# Opciono — Red Alert webhook
# ALERT_WEBHOOK_URL=https://...
