# Database (PostgreSQL via Docker or external)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ekonobar"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# Mapbox (for map features)
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoiZXhhbXBsZSIsImEiOiJleGFtcGxlIn0.example"

# Optional: Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: Facebook OAuth
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# App URL (used for share links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron secret — required to call /api/cron/* routes
# Generate: openssl rand -hex 32
CRON_SECRET="your-cron-secret-min-32-chars"

# Web Push (VAPID) — run: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_KEY=""   # same as VAPID_PUBLIC_KEY, exposed to browser

# WhatsApp Business API (Meta Cloud API)
WA_ACCESS_TOKEN=""
WA_PHONE_NUMBER_ID=""
WA_TEMPLATE_NAME="ekonobar_notification"   # must be approved in Meta Business Manager

# Infobip SMS (premium opt-in only)
INFOBIP_API_KEY=""
INFOBIP_BASE_URL="https://api.infobip.com"  # or your regional base URL
INFOBIP_FROM="eKonobar"                     # sender ID (max 11 chars)

# Monri payment gateway (Visa/Mastercard/DinaCard)
# Get credentials from: https://dashboard.monri.com
# Test endpoint used automatically unless MONRI_ENV=production
MONRI_ENV="test"                            # "test" | "production"
MONRI_MERCHANT_KEY=""                       # from Monri dashboard → API keys
MONRI_AUTHENTICITY_TOKEN=""                 # from Monri dashboard → API keys
