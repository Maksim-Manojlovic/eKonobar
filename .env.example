# Database (PostgreSQL via Docker or external)
DATABASE_URL="postgresql://postgres:password@localhost:5432/ekonobar"

# Redis — required in production for distributed locks and cross-instance token revocation.
# Optional in development (features degrade gracefully without it).
# Local: run `docker run -p 6379:6379 redis:7-alpine`
REDIS_URL="redis://localhost:6379"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-nextauth-secret-min-32-chars"

# SMTP (password reset emails) — works with Gmail, Outlook, SendGrid, etc.
# Gmail: enable "App Passwords" in Google Account settings, use app password as SMTP_PASS
SMTP_HOST="smtp.gmail.com"
SMTP_PORT="587"
SMTP_SECURE="false"              # true for port 465 (SSL), false for 587 (STARTTLS)
SMTP_USER="your@gmail.com"
SMTP_PASS="your-app-password"
SMTP_FROM="eKonobar <noreply@ekonobar.rs>"

# Mapbox (for map features)
NEXT_PUBLIC_MAPBOX_TOKEN="pk.eyJ1IjoiZXhhbXBsZSIsImEiOiJleGFtcGxlIn0.example"

# Optional: Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Optional: Facebook OAuth
FACEBOOK_CLIENT_ID=""
FACEBOOK_CLIENT_SECRET=""

# App URL (used for share links)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Cron secret — required to call /api/cron/* routes
# Generate: openssl rand -hex 32
CRON_SECRET="your-cron-secret-min-32-chars"

# Trusted proxy flag — set to "1" ONLY when the app runs behind a reverse proxy or
# load balancer (Vercel, Railway, fly.io, nginx) that writes X-Forwarded-For correctly.
# Without this, X-Forwarded-For is ignored and IP-based rate limits use req.ip instead.
# Leaving it unset in dev is safe and correct.
# TRUST_PROXY="1"

# Web Push (VAPID) — run: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=""
VAPID_PRIVATE_KEY=""
NEXT_PUBLIC_VAPID_KEY=""   # same as VAPID_PUBLIC_KEY, exposed to browser

# WhatsApp Business API (Meta Cloud API)
WA_ACCESS_TOKEN=""
WA_PHONE_NUMBER_ID=""
WA_TEMPLATE_NAME="ekonobar_notification"   # must be approved in Meta Business Manager

# Infobip SMS (premium opt-in only)
INFOBIP_API_KEY=""
INFOBIP_BASE_URL="https://api.infobip.com"  # or your regional base URL
INFOBIP_FROM="eKonobar"                     # sender ID (max 11 chars)

# Monri payment gateway (Visa/Mastercard/DinaCard)
# Get credentials from: https://dashboard.monri.com
# Test endpoint used automatically unless MONRI_ENV=production
MONRI_ENV="test"                            # "test" | "production"
MONRI_MERCHANT_KEY=""                       # from Monri dashboard → API keys
MONRI_AUTHENTICITY_TOKEN=""                 # from Monri dashboard → API keys
# AES-256-GCM key for encrypting stored pan_tokens at rest.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# REQUIRED in production. Omitting it in dev is safe (tokens stored as plaintext).
MONRI_TOKEN_ENCRYPTION_KEY=""
